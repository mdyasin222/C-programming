#include<bits/stdc++.h>
using namespace std;

int main(){
       int n;cin>>n;
       map<int,int>mp;

       for(int i=0;i<n;i++){
        int l,r;cin>>l>>r;

        mp[l]++;
        mp[r+1]--;
       }
       
       
long long sum=0;
long long int ok=1;
       
       for(auto [x,y] :mp){
           sum+=y;
           if(sum>2){
               ok=0;
               break;
           }
       
       }
       if(ok==1)cout<<"YES\n";
       else cout<<"NO\n";
       

    return 0;

}
