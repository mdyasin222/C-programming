#include <bits/stdc++.h>
using namespace std;

int main() {
	// your code goes here
	int n,m;cin>>n>>m;
	vector<long long int >a(n),b(m) ;
	for(long long int i=0;i<n;i++)cin>>a[i];
		for(long long int i=0;i<m;i++)cin>>b[i];
		long long l=0,r=0,ans=0;
		
		while(l<n&&r<m){
		    long long cnt1=0,cnt2=0;
		    long long cur=a[l];
		    while(l<n && a[l]==cur){
		        cnt1++;l++;
		    }
		    while(r<m && cur>b[r]){
		        r++;
		    }
		    while(r<m && b[r]==cur){
		        cnt2++;
		        r++;
		    }
		    ans=ans+(cnt2*cnt1);
		    
		}
     cout<<ans;
	

}
